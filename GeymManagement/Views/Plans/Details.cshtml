@model PlanIndexViewModel

@{
    ViewData["Title"] = $"{Model.Name} - Plan Details";
}

<!-- Iron UI Styles -->
<link rel="stylesheet" href="~/css/iron-ui.css" />

<div class="iron-container">
    <!-- Page Header -->
    <div class="iron-page-header">
        <h1 class="iron-title">PLAN DETAILS</h1>
        <p class="iron-subtitle">View complete information about this membership plan</p>
    </div>

    <div class="details-container">
        <div class="details-card animate-in">
            <!-- Header -->
            <div class="details-header">
                <h2 class="plan-card-title" style="font-size: 2rem; margin-bottom: var(--space-md);">@Model.Name</h2>
                @if (Model.IsActive)
                {
                    <span class="status-badge status-active">Active Plan</span>
                }
                else
                {
                    <span class="status-badge status-inactive">Inactive Plan</span>
                }
            </div>

            <!-- Body -->
            <div class="details-body">
                <!-- Price Display -->
                <div class="plan-price-section" style="margin-bottom: var(--space-2xl);">
                    <span class="plan-price" style="font-size: 4rem;">@Model.Price</span>
                    <span class="plan-currency" style="font-size: 1.25rem;">EGP</span>
                </div>

                <!-- Details Grid -->
                <div class="details-grid">
                    <!-- Duration -->
                    <div class="details-block">
                        <div class="details-label">Duration</div>
                        <div class="details-value">@Model.DurationInDays Days</div>
                    </div>

                    <!-- Status -->
                    <div class="details-block">
                        <div class="details-label">Status</div>
                        <div class="details-value" style="color: @(Model.IsActive ? "var(--lime)" : "var(--ember)");">
                            @(Model.IsActive ? "Active" : "Inactive")
                        </div>
                    </div>

                    <!-- Description -->
                    <div class="details-block details-block-full">
                        <div class="details-label">Description</div>
                        <div class="details-value">@Model.Description</div>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div class="details-footer">
                <a asp-action="Index" class="btn btn-secondary">
                    ← Back to Plans
                </a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                    Edit Plan
                </a>
            </div>
        </div>
    </div>
</div>
