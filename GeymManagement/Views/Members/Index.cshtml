@model IEnumerable<MemberIndexViewModel>
@{
    ViewData["Title"] = "Members";
}

<!-- Iron UI Styles -->
<link rel="stylesheet" href="~/css/iron-ui.css" />

<div class="iron-container">
    <!-- Page Header -->
    <div class="iron-page-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: var(--space-lg);">
        <div>
            <h1 class="iron-title">MEMBERS</h1>
            <p class="iron-subtitle">Manage your gym members and their memberships</p>
        </div>
        <a asp-controller="Members" asp-action="Create" class="btn btn-primary btn-lg">
            <span style="font-size: 1.25rem; font-weight: 700;">+</span>
            Add Member
        </a>
    </div>

    <!-- Alert Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible animate-in" data-auto-dismiss="5000">
            <span class="alert-icon">✓</span>
            <span>@TempData["SuccessMessage"]</span>
            <button type="button" class="alert-close" onclick="dismissAlert(this)">×</button>
            <div class="alert-progress"></div>
        </div>
    }
    else if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible animate-in" data-auto-dismiss="5000">
            <span class="alert-icon">⚠️</span>
            <span>@TempData["ErrorMessage"]</span>
            <button type="button" class="alert-close" onclick="dismissAlert(this)">×</button>
            <div class="alert-progress"></div>
        </div>
    }

    @if (Model.Any())
    {
        <!-- Members Table -->
        <div class="glass-card animate-in" style="overflow-x: auto;">
            <table class="data-table" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr>
                        <th style="padding: var(--space-lg); text-align: left; border-bottom: 1px solid var(--steel-line); color: var(--text-muted); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em;">Photo</th>
                        <th style="padding: var(--space-lg); text-align: left; border-bottom: 1px solid var(--steel-line); color: var(--text-muted); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em;">Name</th>
                        <th style="padding: var(--space-lg); text-align: left; border-bottom: 1px solid var(--steel-line); color: var(--text-muted); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em;">Email</th>
                        <th style="padding: var(--space-lg); text-align: left; border-bottom: 1px solid var(--steel-line); color: var(--text-muted); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em;">Gender</th>
                        <th style="padding: var(--space-lg); text-align: left; border-bottom: 1px solid var(--steel-line); color: var(--text-muted); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em;">Phone</th>
                        <th style="padding: var(--space-lg); text-align: left; border-bottom: 1px solid var(--steel-line); color: var(--text-muted); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var member in Model)
                    {
                        <tr style="transition: background 0.2s ease;">
                            <td style="padding: var(--space-lg); border-bottom: 1px solid var(--steel-line);">
                                <div class="member-avatar member-avatar--orange" style="width: 40px; height: 40px;">
                                    @if (string.IsNullOrWhiteSpace(member.PhotoPath))
                                    {
                                        <span>@(member.Name.Length >= 2 ? member.Name.Substring(0, 2).ToUpper() : member.Name.ToUpper())</span>
                                    }
                                    else
                                    {
                                        <img src="@member.PhotoPath" alt="@member.Name" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;" />
                                    }
                                </div>
                            </td>
                            <td style="padding: var(--space-lg); border-bottom: 1px solid var(--steel-line); color: var(--text-primary); font-weight: 500;">@member.Name</td>
                            <td style="padding: var(--space-lg); border-bottom: 1px solid var(--steel-line); color: var(--text-secondary);">@member.Email</td>
                            <td style="padding: var(--space-lg); border-bottom: 1px solid var(--steel-line); color: var(--text-secondary);">@member.Gender</td>
                            <td style="padding: var(--space-lg); border-bottom: 1px solid var(--steel-line); color: var(--text-secondary);">@member.PhoneNumber</td>
                            <td style="padding: var(--space-lg); border-bottom: 1px solid var(--steel-line);">
                                <div style="display: flex; gap: var(--space-sm);">
                                    <a asp-controller="Members" asp-action="Details" asp-route-id="@member.Id" class="btn btn-secondary btn-sm" title="View Details">
                                        👁️
                                    </a>
                                    <a asp-controller="Members" asp-action="HealthRecord" asp-route-id="@member.Id" class="btn btn-secondary btn-sm" title="Health Record">
                                        🏥
                                    </a>
                                    <a asp-controller="Members" asp-action="Edit" asp-route-id="@member.Id" class="btn btn-primary btn-sm" title="Edit">
                                        ✏️
                                    </a>
                                    <a asp-controller="Members" asp-action="Delete" asp-route-id="@member.Id" class="btn btn-danger btn-sm" title="Delete">
                                        🗑️
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <!-- Empty State -->
        <div class="empty-state animate-in">
            <div class="empty-icon">👥</div>
            <h2 class="empty-title">No Members Available</h2>
            <p class="empty-text">Add your first member to get started</p>
            <a asp-controller="Members" asp-action="Create" class="btn btn-primary btn-lg">
                <span style="font-size: 1.25rem; font-weight: 700;">+</span>
                Add First Member
            </a>
        </div>
    }
</div>

@section Scripts {
    <partial name="_AlertDismissScript"/>
}
