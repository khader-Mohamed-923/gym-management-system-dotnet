@model IEnumerable<PlanIndexViewModel>

@{
    ViewData["Title"] = "Membership Plans";
}

<!-- Iron UI Styles -->
<link rel="stylesheet" href="~/css/iron-ui.css" />

<div class="iron-container">
    <!-- Page Header -->
    <div class="iron-page-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: var(--space-lg);">
        <div>
            <h1 class="iron-title">MEMBERSHIP PLANS</h1>
            <p class="iron-subtitle">Configure and manage your gym membership packages</p>
        </div>
    </div>



    <!-- Alert Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible animate-in" data-auto-dismiss="5000">
            <span class="alert-icon">✓</span>
            <span>@TempData["SuccessMessage"]</span>
            <button type="button" class="alert-close" onclick="dismissAlert(this)">×</button>
            <div class="alert-progress"></div>
        </div>
    }
    else if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible animate-in" data-auto-dismiss="5000">
            <span class="alert-icon">⚠️</span>
            <span>@TempData["ErrorMessage"]</span>
            <button type="button" class="alert-close" onclick="dismissAlert(this)">×</button>
            <div class="alert-progress"></div>
        </div>
    }

    @if (Model.Any())
    {
        <div class="plans-grid">
            @foreach (var plan in Model)
            {
                <div class="plan-card animate-in @(!plan.IsActive ? "inactive" : "")">
                    <!-- Card Header -->
                    <div class="plan-card-header" style="@(plan.IsActive ? "" : "background: rgba(163, 163, 163, 0.1);")">
                        <h3 class="plan-card-title" style="@(plan.IsActive ? "" : "color: var(--text-secondary);")">@plan.Name</h3>
                        @if (plan.IsActive)
                        {
                            <span class="status-badge status-active">Active</span>
                        }
                        else
                        {
                            <span class="status-badge status-inactive">Inactive</span>
                        }
                    </div>

                    <!-- Card Body -->
                    <div class="plan-card-body">
                        <!-- Price Section -->
                        <div class="plan-price-section">
                            <span class="plan-price" style="@(plan.IsActive ? "" : "color: var(--text-secondary);")">@plan.Price</span>
                            <span class="plan-currency">EGP</span>
                            <div class="plan-period">/ @plan.DurationInDays days</div>
                        </div>

                        <!-- Features List -->
                        <ul class="plan-features">
                            <li>Duration: @plan.DurationInDays days</li>
                            <li>@plan.Description</li>
                        </ul>

                        <!-- Actions -->
                        <div class="plan-card-actions">
                            <a asp-action="Details" asp-route-id="@plan.Id" class="btn btn-secondary" style="flex: 1;">
                                View Details
                            </a>
                            <a asp-action="Edit" asp-route-id="@plan.Id" class="btn btn-primary" style="flex: 1;">
                                Edit
                            </a>
                        </div>

                        <form asp-action="Activate" asp-route-id="@plan.Id" method="post" style="margin-top: var(--space-sm);">
                            @Html.AntiForgeryToken()
                            @if (plan.IsActive)
                            {
                                <button type="submit" class="btn btn-danger btn-block">
                                    Deactivate Plan
                                </button>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-success btn-block">
                                    Activate Plan
                                </button>
                            }
                        </form>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- Empty State -->
        <div class="empty-state animate-in">
            <div class="empty-icon">📋</div>
            <h2 class="empty-title">No Plans Available</h2>
            <p class="empty-text">Get started by creating your first membership plan</p>
            <a asp-action="Create" class="btn btn-primary btn-lg">
                <span style="font-size: 1.25rem; font-weight: 700;">+</span>
                Create First Plan
            </a>
        </div>
    }
</div>
