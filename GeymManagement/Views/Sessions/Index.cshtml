@model IEnumerable<GymManagement.Presentation.ViewModels.Session.SessionIndexViewModel>

@{
    ViewData["Title"] = "Sessions";
}

<link rel="stylesheet" href="~/css/iron-ui.css" />

<div class="iron-container">
    <div class="iron-page-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: var(--space-lg);">
        <div>
            <h1 class="iron-title">SESSIONS</h1>
            <p class="iron-subtitle">Manage gym training sessions and classes</p>
        </div>
        <a asp-controller="Sessions" asp-action="Create" class="btn btn-primary btn-lg">
            <span style="font-size: 1.25rem; font-weight: 700;">+</span>
            Add Session
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible animate-in" data-auto-dismiss="5000">
            <span class="alert-icon">✓</span>
            <span>@TempData["SuccessMessage"]</span>
            <button type="button" class="alert-close" onclick="dismissAlert(this)">×</button>
            <div class="alert-progress"></div>
        </div>
    }
    else if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible animate-in" data-auto-dismiss="5000">
            <span class="alert-icon">⚠️</span>
            <span>@TempData["ErrorMessage"]</span>
            <button type="button" class="alert-close" onclick="dismissAlert(this)">×</button>
            <div class="alert-progress"></div>
        </div>
    }

    @if (Model.Any())
    {
        <div class="sessions-grid">
            @foreach (var session in Model)
            {
                <div class="session-card animate-in">
                    <div class="session-card-header">
                        <div class="session-category-badge">
                            @session.CategoryName
                        </div>
                        <span class="session-status-badge session-status-@session.Status.ToLower()">
                            @session.Status
                        </span>
                    </div>

                    <div class="session-card-body">
                        <h3 class="session-title">@session.Description</h3>
                        
                        <div class="session-info-grid">
                            <div class="session-info-item">
                                <span class="session-info-icon">👨‍🏫</span>
                                <span class="session-info-label">Trainer</span>
                                <span class="session-info-value">@session.TrainerName</span>
                            </div>
                            
                            <div class="session-info-item">
                                <span class="session-info-icon">📅</span>
                                <span class="session-info-label">Date</span>
                                <span class="session-info-value">@session.StartDate.ToString("MMM dd, yyyy")</span>
                            </div>
                            
                            <div class="session-info-item">
                                <span class="session-info-icon">🕐</span>
                                <span class="session-info-label">Time</span>
                                <span class="session-info-value">@session.StartDate.ToString("HH:mm") - @session.EndDate.ToString("HH:mm")</span>
                            </div>
                            
                            <div class="session-info-item">
                                <span class="session-info-icon">⏱️</span>
                                <span class="session-info-label">Duration</span>
                                <span class="session-info-value">@((session.EndDate - session.StartDate).TotalMinutes) min</span>
                            </div>
                            
                            <div class="session-info-item">
                                <span class="session-info-icon">👥</span>
                                <span class="session-info-label">Capacity</span>
                                <span class="session-info-value">@session.BookedCount/@session.Capacity slots</span>
                            </div>
                        </div>
                    </div>

                    <div class="session-card-actions">
                        <a asp-controller="Sessions" asp-action="Details" asp-route-id="@session.Id" class="btn btn-secondary" style="flex: 1;">
                            View Details
                        </a>
                        <a asp-controller="Sessions" asp-action="Edit" asp-route-id="@session.Id" class="btn btn-primary" style="flex: 1;">
                            Edit
                        </a>
                        <a asp-controller="Sessions" asp-action="Delete" asp-route-id="@session.Id" class="btn btn-danger" style="flex: 1;">
                            Delete
                        </a>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state animate-in">
            <div class="empty-icon">🗓️</div>
            <h2 class="empty-title">No Sessions Available</h2>
            <p class="empty-text">Schedule your first training session</p>
            <a asp-controller="Sessions" asp-action="Create" class="btn btn-primary btn-lg">
                <span style="font-size: 1.25rem; font-weight: 700;">+</span>
                Create First Session
            </a>
        </div>
    }
</div>

<style>
    .sessions-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: var(--space-xl);
    }

    .session-card {
        background: var(--glass-fill);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid var(--glass-border);
        border-radius: var(--radius-lg);
        padding: var(--space-xl);
        transition: all 0.25s ease;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .session-card:hover {
        background: var(--glass-hover);
        border-color: rgba(255, 255, 255, 0.12);
        transform: translateY(-4px);
        box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4);
    }

    .session-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: var(--space-lg);
        padding-bottom: var(--space-md);
        border-bottom: 1px solid var(--steel-line);
    }

    .session-category-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.35rem 0.85rem;
        border-radius: var(--radius-full);
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        background: rgba(56, 189, 248, 0.12);
        color: var(--ice);
        border: 1px solid rgba(56, 189, 248, 0.25);
    }

    .session-status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.25rem 0.75rem;
        border-radius: var(--radius-full);
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    .session-status-badge::before {
        content: '';
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: currentColor;
    }

    .session-status-upcoming {
        background: rgba(56, 189, 248, 0.12);
        color: var(--ice);
        border: 1px solid rgba(56, 189, 248, 0.25);
    }

    .session-status-ongoing {
        background: rgba(132, 204, 22, 0.12);
        color: var(--lime);
        border: 1px solid rgba(132, 204, 22, 0.25);
    }

    .session-status-completed {
        background: rgba(163, 163, 163, 0.12);
        color: #a3a3a3;
        border: 1px solid rgba(163, 163, 163, 0.25);
    }

    .session-card-body {
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .session-title {
        font-family: var(--font-display);
        font-size: 1.25rem;
        font-weight: 400;
        letter-spacing: 0.02em;
        margin: 0 0 var(--space-lg) 0;
        color: var(--text-primary);
        line-height: 1.3;
    }

    .session-info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-md);
        flex: 1;
    }

    .session-info-item {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
        padding: var(--space-sm);
        background: rgba(255, 255, 255, 0.02);
        border-radius: var(--radius-sm);
    }

    .session-info-icon {
        font-size: 1rem;
    }

    .session-info-label {
        font-size: 0.65rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--text-muted);
    }

    .session-info-value {
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--text-primary);
    }

    .session-card-actions {
        display: flex;
        gap: var(--space-sm);
        margin-top: var(--space-lg);
        padding-top: var(--space-lg);
        border-top: 1px solid var(--steel-line);
    }

    @@media (max-width: 768px) {
        .sessions-grid {
            grid-template-columns: 1fr;
        }

        .session-info-grid {
            grid-template-columns: 1fr;
        }

        .session-card-actions {
            flex-direction: column;
        }
    }
</style>

@section Scripts {
    <partial name="_AlertDismissScript"/>
}
