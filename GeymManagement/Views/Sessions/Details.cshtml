@model GymManagement.Presentation.ViewModels.Session.SessionDetailsViewModel

@{
    ViewData["Title"] = "Session Details";
}

<link rel="stylesheet" href="~/css/iron-ui.css" />

<div class="iron-container">
    <div class="iron-page-header">
        <h1 class="iron-title">SESSION DETAILS</h1>
        <p class="iron-subtitle">View session information</p>
    </div>

    <div class="details-container">
        <div class="details-card animate-in">
            <div class="details-header">
                <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: var(--space-md);">
                    <span class="session-category-badge">@Model.CategoryName</span>
                    <span class="session-status-badge session-status-@Model.Status.ToLower()">@Model.Status</span>
                </div>
                <h2 style="font-family: var(--font-display); font-size: 2rem; margin: var(--space-lg) 0 0 0; color: var(--text-primary);">@Model.Description</h2>
            </div>

            <div class="details-body">
                <h3 class="iron-subtitle" style="margin-bottom: var(--space-xl); text-transform: uppercase; letter-spacing: 0.08em; color: var(--fire);">
                    SCHEDULE INFORMATION
                </h3>

                <div class="details-grid">
                    <div class="details-block">
                        <div class="details-label">Start Date</div>
                        <div class="details-value">@Model.StartDate.ToString("MMM dd, yyyy")</div>
                    </div>
                    <div class="details-block">
                        <div class="details-label">Start Time</div>
                        <div class="details-value">@Model.StartDate.ToString("HH:mm")</div>
                    </div>
                    <div class="details-block">
                        <div class="details-label">End Date</div>
                        <div class="details-value">@Model.EndDate.ToString("MMM dd, yyyy")</div>
                    </div>
                    <div class="details-block">
                        <div class="details-label">End Time</div>
                        <div class="details-value">@Model.EndDate.ToString("HH:mm")</div>
                    </div>
                    <div class="details-block">
                        <div class="details-label">Duration</div>
                        <div class="details-value">@((int)(Model.EndDate - Model.StartDate).TotalMinutes) minutes</div>
                    </div>
                    <div class="details-block">
                        <div class="details-label">Capacity</div>
                        <div class="details-value">@Model.BookedCount / @Model.Capacity slots</div>
                    </div>
                </div>

                <hr class="divider" />

                <h3 class="iron-subtitle" style="margin-bottom: var(--space-xl); text-transform: uppercase; letter-spacing: 0.08em; color: var(--ice);">
                    TRAINER INFORMATION
                </h3>

                <div class="details-grid">
                    <div class="details-block">
                        <div class="details-label">Trainer Name</div>
                        <div class="details-value">@Model.TrainerName</div>
                    </div>
                    <div class="details-block">
                        <div class="details-label">Specialization</div>
                        <div class="details-value">@Model.TrainerSpecialization</div>
                    </div>
                    <div class="details-block">
                        <div class="details-label">Email</div>
                        <div class="details-value">@Model.TrainerEmail</div>
                    </div>
                    <div class="details-block">
                        <div class="details-label">Phone</div>
                        <div class="details-value">@Model.TrainerPhone</div>
                    </div>
                </div>
            </div>

            <div class="details-footer">
                <a asp-controller="Sessions" asp-action="Index" class="btn btn-secondary">
                    ← Back to Sessions
                </a>
                <div style="display: flex; gap: var(--space-md);">
                    <a asp-controller="Sessions" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                        Edit
                    </a>
                    <a asp-controller="Sessions" asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                        Delete
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .session-category-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.35rem 0.85rem;
        border-radius: var(--radius-full);
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        background: rgba(56, 189, 248, 0.12);
        color: var(--ice);
        border: 1px solid rgba(56, 189, 248, 0.25);
    }

    .session-status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.25rem 0.75rem;
        border-radius: var(--radius-full);
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    .session-status-badge::before {
        content: '';
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: currentColor;
    }

    .session-status-upcoming {
        background: rgba(56, 189, 248, 0.12);
        color: var(--ice);
        border: 1px solid rgba(56, 189, 248, 0.25);
    }

    .session-status-ongoing {
        background: rgba(132, 204, 22, 0.12);
        color: var(--lime);
        border: 1px solid rgba(132, 204, 22, 0.25);
    }

    .session-status-completed {
        background: rgba(163, 163, 163, 0.12);
        color: #a3a3a3;
        border: 1px solid rgba(163, 163, 163, 0.25);
    }
</style>
