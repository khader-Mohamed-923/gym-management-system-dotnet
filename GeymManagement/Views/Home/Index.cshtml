@{
    ViewData["Title"] = "Dashboard";
}


<link rel="stylesheet" href="~/css/iron-ui.css" />

<div class="iron-container">
    
    <div class="iron-page-header" style="text-align: center; padding: var(--space-3xl) 0;">
        <h1 class="iron-title" style="font-size: 4rem; margin-bottom: var(--space-lg);">
            GOOD MORNING, ADMIN
        </h1>
        <p class="iron-subtitle" style="font-size: 1.25rem; color: var(--text-secondary);">
            Today is going to be a strong day. Your gym is performing well.
        </p>
    </div>

    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: var(--space-xl); margin-bottom: var(--space-3xl);">
        
        <div class="glass-card glow-card-lime animate-in" style="text-align: center;">
            <p class="form-label" style="color: var(--lime); margin-bottom: var(--space-md);">Active Members</p>
            <p class="plan-price" style="font-size: 3rem;">85</p>
            <p class="iron-subtitle" style="color: var(--lime);">↑ 12 joined this week</p>
        </div>

        
        <div class="glass-card glow-card-fire animate-in" style="text-align: center;">
            <p class="form-label" style="color: var(--fire); margin-bottom: var(--space-md);">Today's Check-ins</p>
            <p class="plan-price" style="font-size: 3rem;">67</p>
            <p class="iron-subtitle" style="color: var(--text-secondary);">Peak: 9–11 AM</p>
        </div>

        
        <div class="glass-card glow-card-red animate-in" style="text-align: center;">
            <p class="form-label" style="color: var(--ember); margin-bottom: var(--space-md);">Expiring This Week</p>
            <p class="plan-price" style="font-size: 3rem;">14</p>
            <p class="iron-subtitle" style="color: var(--text-secondary);">Renewal reminders sent</p>
        </div>

        
        <div class="glass-card glow-card-gold animate-in" style="text-align: center;">
            <p class="form-label" style="color: var(--gold); margin-bottom: var(--space-md);">Revenue (MTD)</p>
            <p class="plan-price" style="font-size: 3rem;">24.5K</p>
            <p class="iron-subtitle" style="color: var(--text-secondary);">EGP</p>
        </div>
    </div>

    
    <div class="glass-card animate-in" style="margin-bottom: var(--space-3xl);">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: var(--space-lg); text-align: center; padding: var(--space-lg);">
            <div>
                <p class="details-value" style="font-size: 2rem; color: var(--fire);">100</p>
                <p class="details-label">Total Members</p>
            </div>
            <div>
                <p class="details-value" style="font-size: 2rem; color: var(--lime);">85</p>
                <p class="details-label">Active</p>
            </div>
            <div>
                <p class="details-value" style="font-size: 2rem; color: var(--ice);">20</p>
                <p class="details-label">Trainers</p>
            </div>
            <div>
                <p class="details-value" style="font-size: 2rem; color: var(--gold);">3</p>
                <p class="details-label">Upcoming Sessions</p>
            </div>
            <div>
                <p class="details-value" style="font-size: 2rem; color: var(--fire);">5</p>
                <p class="details-label">Ongoing Sessions</p>
            </div>
            <div>
                <p class="details-value" style="font-size: 2rem; color: var(--lime);">20</p>
                <p class="details-label">Completed</p>
            </div>
        </div>
    </div>

    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: var(--space-xl); margin-bottom: var(--space-3xl);">
        
        <div class="glass-card animate-in card-hover" style="padding: var(--space-2xl);">
            <div style="display: flex; align-items: center; gap: var(--space-md); margin-bottom: var(--space-lg);">
                <div style="width: 50px; height: 50px; background: rgba(249, 115, 22, 0.15); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center;">
                    <span style="font-size: 1.5rem;">👥</span>
                </div>
                <div>
                    <h3 class="iron-title" style="font-size: 1.5rem;">Members</h3>
                    <p class="iron-subtitle">Manage gym members</p>
                </div>
            </div>
            <a asp-controller="Members" asp-action="Index" class="btn btn-primary btn-block">
                View All Members
            </a>
        </div>

        
        <div class="glass-card animate-in card-hover" style="padding: var(--space-2xl);">
            <div style="display: flex; align-items: center; gap: var(--space-md); margin-bottom: var(--space-lg);">
                <div style="width: 50px; height: 50px; background: rgba(132, 204, 22, 0.15); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center;">
                    <span style="font-size: 1.5rem;">💳</span>
                </div>
                <div>
                    <h3 class="iron-title" style="font-size: 1.5rem;">Plans</h3>
                    <p class="iron-subtitle">Membership packages</p>
                </div>
            </div>
            <a asp-controller="Plans" asp-action="Index" class="btn btn-success btn-block">
                View All Plans
            </a>
        </div>

        
        <div class="glass-card animate-in card-hover" style="padding: var(--space-2xl);">
            <div style="display: flex; align-items: center; gap: var(--space-md); margin-bottom: var(--space-lg);">
                <div style="width: 50px; height: 50px; background: rgba(56, 189, 248, 0.15); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center;">
                    <span style="font-size: 1.5rem;">📅</span>
                </div>
                <div>
                    <h3 class="iron-title" style="font-size: 1.5rem;">Sessions</h3>
                    <p class="iron-subtitle">Training schedule</p>
                </div>
            </div>
            <a href="#" class="btn btn-secondary btn-block" style="opacity: 0.6; cursor: not-allowed;">
                Coming Soon
            </a>
        </div>
    </div>

    
    <div class="glass-card animate-in" style="text-align: center; padding: var(--space-3xl); background: linear-gradient(135deg, rgba(249, 115, 22, 0.1), rgba(239, 68, 68, 0.05));">
        <h2 class="iron-title" style="font-size: 2.5rem; margin-bottom: var(--space-lg);">
            YOUR BODY CAN STAND ALMOST ANYTHING
        </h2>
        <p class="iron-subtitle" style="font-size: 1.125rem; max-width: 600px; margin: 0 auto var(--space-xl);">
            It's your mind that needs convincing. Push past your limits, stay committed, and watch as your body transforms into a powerhouse of strength and resilience.
        </p>
        <div style="display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap;">
            <button class="btn btn-primary btn-lg">Get Started</button>
            <button class="btn btn-secondary btn-lg">Explore More</button>
        </div>
    </div>
</div>
